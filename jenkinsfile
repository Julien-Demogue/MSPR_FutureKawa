pipeline {
    agent any

    tools {
        // Assurez-vous que 'nodejs' est configuré dans Gérer Jenkins -> Configuration globale des outils
        nodejs 'node'
    }

    environment {
        SCANNER_HOME = tool 'SonarScanner'
        }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Installation des dépendances...'
                sh 'cd ./backend_country && npm install'
                sh 'cd ./backend_head_office && npm install'
                sh 'cd ./frontend/app_head_office && npm install'
            }
        }

        stage('Build') {
            steps {
                echo 'Compilation du projet TypeScript...'
                sh 'cd ./backend_country && npm run build'
                sh 'cd ./backend_head_office && npm run build'
                sh 'cd ./frontend/app_head_office && npm run build'
                sh 'tar -czvf backend_country.tar.gz -C ./backend_country dist'
                sh 'tar -czvf backend_head_office.tar.gz -C ./backend_head_office dist'
                sh 'tar -czvf frontend.tar.gz -C ./frontend/app_head_office dist'
            }
        }

        stage('Unit Tests') {
            steps {
                echo 'Exécution des tests unitaires...'
                sh 'cd ./backend_country && npm run test'
                sh 'cd ./backend_head_office && npm run test'
            }
            post {
                always {
                    junit '**/backend_country/junit.xml'
                    junit '**/backend_head_office/junit.xml'
                }
            }
        }
        stage("e2e tests") {
            steps {
                echo 'Exécution des tests e2e...'
                sh 'cd ./backend_country && echo "DB_HOST=host.docker.internal\nCOUNTRY_API_SECRET=\"12345678\"MQTT_BROKER_HOST=host.docker.internal\nEMAIL_ADDRESS=support.futurekawa@gmail.com\nEMAIL_APP_PASSWORD=\"owgv lwqw czwx ayct\"" > .env'
                sh 'cd ./backend_head_office && echo "DB_HOST=host.docker.internal\nDB_PORT=3307\nDB_USER=root\nDB_PASSWORD=root\nDB_NAME=FutureKawa\nPORT=3001\nJWT_ACCESS_SECRET=\nJWT_REFRESH_SECRET=\nDEFAULT_ADMIN_EMAIL=admintest3@email.com\nDEFAULT_ADMIN_PASSWORD=Admin1234!\nDEFAULT_ADMIN_FIRST_NAME=Admin\nDEFAULT_ADMIN_LAST_NAME=FutureKawa\nDEFAULT_ADMIN_ROLE=admin\nSEED_DEMO_USERS_JSON=\nBASE_URL=http://host.docker.internal:3001\nFRONT_URL=http://host.docker.internal:5173\nJWT_SECRET=your_jwt_secret\nCOUNTRY_API_SECRET=\"12345678\"" > .env'
                sh 'docker compose up -d'
                sh 'docker compose -f docker-compose-head-office.yml up -d'
                sh 'cd ./frontend/app_head_office && npx playwright install'
                sh 'cd ./frontend/app_head_office && npx playwright test'
                sh 'docker compose down'
                sh 'docker compose -f docker-compose-head-office.yml down'
            }
        }

        stage('SonarQube Analysis country') {
            steps {
                echo 'Analyse SonarQube...'
                withSonarQubeEnv('SonarQube') {
                        sh "cd ./backend_country && ${SCANNER_HOME}/bin/sonar-scanner"
                        sh "cd ./backend_head_office && ${SCANNER_HOME}/bin/sonar-scanner"
                        sh "cd ./frontend/app_head_office && ${SCANNER_HOME}/bin/sonar-scanner"
                }
            }
        }
        stage('Deploy'){
            steps {
                echo 'Déploiement...'
                withCredentials([usernamePassword(credentialsId: 'nexus-credentials-id', passwordVariable: 'NEXUS_PWD', usernameVariable: 'NEXUS_USR')]){
                sh 'curl -v -u "${NEXUS_USR}:${NEXUS_PWD}" --upload-file ./backend_head_office.tar.gz "https://nexus.service-eric.duckdns.org/repository/mspr_futurKawa/backend_head_office/backend_head_office.tar.gz"'
                sh 'curl -v -u "${NEXUS_USR}:${NEXUS_PWD}" --upload-file ./backend_country.tar.gz "https://nexus.service-eric.duckdns.org/repository/mspr_futurKawa/backend_country/backend_country.tar.gz"'
                sh 'curl -v -u "${NEXUS_USR}:${NEXUS_PWD}" --upload-file ./frontend.tar.gz "https://nexus.service-eric.duckdns.org/repository/mspr_futurKawa/frontend/frontend.tar.gz"'
            }}
        }
    }

    post {
        success {
            script {
                def message = "✅ **Build Réussi !**\n**Projet :** ${env.JOB_NAME}\n**Build :** #${env.BUILD_NUMBER}\n**Lien :** ${env.BUILD_URL}"
                sendDiscordNotification(message, "65280") // Vert
            }
        }
        failure {
            script {
                def message = "❌ **Build Échoué...**\n**Projet :** ${env.JOB_NAME}\n**Build :** #${env.BUILD_NUMBER}\n**Lien :** ${env.BUILD_URL}"
                sendDiscordNotification(message, "16711680") // Rouge
            }
        }
    }
}

def sendDiscordNotification(String message, String color) {
    def discordWebhookUrl = "https://discord.com/api/webhooks/1501545327461662790/5-S_ltbIfaIsBmyE9FEoJ9aJENq0uiI5daXug8izxCsMJL3O5r6jgUZPPu_fck2ftQ7q"
    
    // 1. On prépare l'objet JSON proprement
    // On remplace les vrais retours à la ligne par le texte "\n" pour le JSON
    def cleanMessage = message.replace("\n", "\\n").replace("\"", "\\\"")

    def payload = """{
        "embeds": [{
            "title": "Statut Pipeline",
            "description": "${cleanMessage}",
            "color": ${color}
        }]
    }"""

    // 2. On écrit le payload dans un fichier temporaire
    writeFile file: 'discord_payload.json', text: payload

    // 3. On envoie le fichier avec @
    sh "curl -H 'Content-Type: application/json' -X POST -d @discord_payload.json ${discordWebhookUrl}"
    
    // 4. Nettoyage
    sh "rm discord_payload.json"
}