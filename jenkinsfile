pipeline {
    agent any

    tools {
        // Assurez-vous que 'nodejs' est configuré dans Gérer Jenkins -> Configuration globale des outils
        nodejs 'node'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Installation des dépendances...'
                sh 'cd ./backend_country && npm install'
                sh 'cd ./backend_head_office && npm install'
            }
        }

        stage('Build') {
            steps {
                echo 'Compilation du projet TypeScript...'
                sh 'cd ./backend_country && npm run build'
                sh 'cd ./backend_head_office && npm run build'
            }
        }

        stage('Unit Tests') {
            steps {
                echo 'Exécution des tests unitaires...'
                sh 'cd ./backend_country && npm run test'
                sh 'cd ./backend_head_office && npm run test'
            }
            post {
                always {
                    // Assurez-vous d'utiliser un formateur de rapports comme jest-junit
                    junit './backend_country/junit.xml'
                    junit './backend_head_office/junit.xml'
                }
            }
        }

        stage('e2e Tests') {
            steps {
                echo 'Exécution des tests e2e...'
                sh 'cd ./backend_country && npm run test:e2e'
                sh 'cd ./backend_head_office && npm run test:e2e'
            }
            post {
                always {
                    // Assurez-vous d'utiliser un formateur de rapports comme jest-junit
                    junit 'e2e-junit.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo 'Analyse SonarQube...'
                withSonarQubeEnv('SonarScanner') {
                        sh "cd ./backend_country && sonar-scanner"
                        sh "cd ./backend_head_office && sonar-scanner"
                }
            }
        }

        stage('Quality Gate') {
            steps {
                echo 'Vérification du Quality Gate...'
                timeout(time: 1, unit: 'HOURS') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }

    post {
        success {
            echo 'Le pipeline a réussi !'
        }
        failure {
            echo 'Le pipeline a échoué.'
        }
    }
}